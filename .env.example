# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# FRED (phase 2)
FRED_API_KEY=

# OpenRouter (phase 3, optional)
OPENROUTER_API_KEY=

# Cloudflare R2 raw data storage
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=quant-raw
R2_REGION=auto

# Runtime
LOG_LEVEL=INFO
LOG_FILE=logs/quant-pipeline.log
TZ=UTC
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
CORRELATION_LOOKBACK_DAYS=120
CORRELATION_BTC_INTERVAL=15m
